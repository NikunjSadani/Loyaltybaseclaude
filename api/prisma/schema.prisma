  @@index([submissionId])
  @@index([imageHash])
  @@map("visibility_image_hashes")
}

// ─── MODULE 11b: OUTLET VISIBILITY UPLOAD ────────────────────────────────────
// Separate from VisibilitySubmission (partner in-app photo capture).
// Tracks admin-uploaded bulk status from the client's external SFA system.
// Each month is an independent cycle — no carry-forward between months.
// ─────────────────────────────────────────────────────────────────────────────

enum OutletVisibilityStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
}

model OutletVisibilityUploadBatch {
  id               String   @id @default(cuid())
  clientId         String
  uploadedByUserId String
  fileName         String
  rowCount         Int
  successCount     Int
  errorCount       Int
  /// Array of { rowNumber, outletCode, reason } for rows that failed validation
  errors           Json?
  createdAt        DateTime @default(now())

  records   OutletVisibilityRecord[]
  auditLogs OutletVisibilityAuditLog[]

  @@index([clientId])
  @@index([createdAt])
  @@map("outlet_visibility_upload_batches")
}

model OutletVisibilityRecord {
  id                      String                 @id @default(cuid())
  clientId                String
  /// Matches Outlet.outletCode from the client's SFA / admin upload template
  outletCode              String
  /// YYYY-MM — each month is an independent visibility cycle
  month                   String
  status                  OutletVisibilityStatus
  dateOfCapture           DateTime?
  approvedBy              String?
  capturedByEmployeeId    String?
  capturedByEmployeeName  String?
  capturedByEmployeePhone String?
  uploadBatchId           String
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  uploadBatch OutletVisibilityUploadBatch @relation(fields: [uploadBatchId], references: [id])

  @@unique([clientId, outletCode, month])
  @@index([clientId, month])
  @@index([clientId, outletCode])
  @@map("outlet_visibility_records")
}

/// Immutable log of every status change per outlet per month.
/// Written only when a new upload changes the stored status (or creates a new record).
model OutletVisibilityAuditLog {
  id               String                  @id @default(cuid())
  clientId         String
  outletCode       String
  month            String
  /// null when this is the first record for the outlet/month
  previousStatus   OutletVisibilityStatus?
  newStatus        OutletVisibilityStatus
  uploadBatchId    String
  uploadedByUserId String
  changedAt        DateTime                @default(now())

  uploadBatch OutletVisibilityUploadBatch @relation(fields: [uploadBatchId], references: [id])

  @@index([clientId, outletCode, month])
  @@index([uploadBatchId])
  @@map("outlet_visibility_audit_logs")
}

