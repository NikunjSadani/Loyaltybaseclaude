  pdfUrl          String?
  emailSentAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId])
  @@index([partnerId])
  @@index([invoiceDate])
  @@map("auto_invoices")
}

// ============================================================
// MODULE 13: LEADERBOARD
// ============================================================

model LeaderboardConfig {
  id              String            @id @default(cuid())
  clientId        String
  code            String            
  name            String
  description     String?
  leaderboardType LeaderboardType
  period          LeaderboardPeriod
  eligibleClasses PartnerClassCode[]
  topN            Int               @default(10)
  rewardPoints    Int?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  snapshots LeaderboardSnapshot[]

  @@index([clientId])
  @@index([leaderboardType])
  @@index([period])
  @@index([isActive])
  @@map("leaderboard_configs")
}

model LeaderboardSnapshot {
  id              String    @id @default(cuid())
  configId        String
  snapshotDate    DateTime
  periodStartDate DateTime
  periodEndDate   DateTime
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  config  LeaderboardConfig  @relation(fields: [configId], references: [id], onDelete: Cascade)
  entries LeaderboardEntry[]

  @@index([configId])
  @@index([snapshotDate])
  @@index([isPublished])
  @@map("leaderboard_snapshots")
}

model LeaderboardEntry {
  id           String   @id @default(cuid())
  snapshotId   String
  partnerId    String
  rank         Int
  score        Decimal  @db.Decimal(15, 2)
  previousRank Int?
  rankChange   Int?
  metadata     Json?
  createdAt    DateTime @default(now())

  snapshot LeaderboardSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  partner  ChannelPartner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, rank])
  @@unique([snapshotId, partnerId])
  @@index([snapshotId])
  @@index([partnerId])
  @@index([rank])
  @@map("leaderboard_entries")
}

// ============================================================
// MODULE 14: SUPPORT
// ============================================================

model Ticket {
  id           String         @id @default(cuid())
  clientId     String         
  ticketNumber String         
  createdById  String
  assignedToId String?
  category     TicketCategory
  priority     TicketPriority @default(MEDIUM)
  status       TicketStatus   @default(OPEN)
  subject      String
  description  String
  referenceType String?
  referenceId  String?
  resolvedAt   DateTime?
  closedAt     DateTime?
  firstResponseAt DateTime?
  slaBreached  Boolean        @default(false)
  metadata     Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  createdBy    User                 @relation("TicketCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignedTo   User?                @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages     TicketMessage[]
  statusHistory TicketStatusHistory[]

  @@index([clientId])
  @@index([createdById])
  @@index([assignedToId])
  @@index([status])
  @@index([category])
  @@index([priority])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("tickets")
}

model TicketMessage {
  id          String   @id @default(cuid())
  ticketId    String
  senderId    String
  message     String
  isInternal  Boolean  @default(false)
  attachments Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User   @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([ticketId])
  @@index([senderId])
  @@index([createdAt])
  @@map("ticket_messages")
}

model TicketStatusHistory {
  id          String       @id @default(cuid())
  ticketId    String
  fromStatus  TicketStatus?
  toStatus    TicketStatus
  changedById String?
  notes       String?
  createdAt   DateTime     @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
  @@map("ticket_status_history")
}

// ============================================================
// MODULE 15: NOTIFICATIONS
// ============================================================

model NotificationTemplate {
  id          String              @id @default(cuid())
  clientId    String              
  code        String              
  name        String
  channel     NotificationChannel
  subject     String?
  bodyTemplate String
  variables   Json?
  isActive    Boolean             @default(true)
  metadata    Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  queue NotificationQueue[]

  @@index([clientId])
  @@index([channel])
  @@index([isActive])
  @@map("notification_templates")
}

model NotificationQueue {
  id           String              @id @default(cuid())
  userId       String
  templateId   String?
  channel      NotificationChannel
  status       NotificationStatus  @default(QUEUED)
  subject      String?
  body         String
  recipientPhone String?
  recipientEmail String?
  recipientFcm   String?
  variables    Json?
  scheduledAt  DateTime?
  processedAt  DateTime?
  retryCount   Int                 @default(0)
  maxRetries   Int                 @default(3)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  user          User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  template      NotificationTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  deliveryLogs  NotificationDeliveryLog[]

  @@index([userId])
  @@index([status])
  @@index([channel])
  @@index([scheduledAt])
  @@index([createdAt])
  @@map("notification_queue")
}

model NotificationDeliveryLog {
  id              String             @id @default(cuid())
  queueId         String
  channel         NotificationChannel
  status          NotificationStatus
  providerRef     String?
  providerResponse Json?
  deliveredAt     DateTime?
  failureReason   String?
  createdAt       DateTime           @default(now())

  queue NotificationQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@index([queueId])
  @@index([status])
  @@index([createdAt])
  @@map("notification_delivery_log")
}

// ============================================================
// MODULE 16: ADMIN
// ============================================================

model AdminConfig {
  id          String   @id @default(cuid())
  clientId    String
  key         String   
  value       Json
  description String?
  isPublic    Boolean  @default(false)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
  @@index([key])
  @@index([isPublic])
  @@map("admin_configs")
}

model BannerManagement {
  id          String       @id @default(cuid())
  clientId    String       
  title       String
  imageUrl    String
  linkUrl     String?
  position    BannerPosition
  status      BannerStatus  @default(INACTIVE)
  targetClasses PartnerClassCode[]
  startDate   DateTime?
  endDate     DateTime?
  sortOrder   Int          @default(0)
  metadata    Json?
  createdByUserId String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  @@index([clientId])
  @@index([position])
  @@index([status])
  @@index([startDate, endDate])
  @@index([deletedAt])
  @@map("banner_management")
}

model ProgramSetting {
  id          String   @id @default(cuid())
  clientId    String
  settingKey  String   
  settingValue Json
  category    String?
  description String?
  isEditable  Boolean  @default(true)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
  @@index([settingKey])
  @@index([category])
  @@map("program_settings")
}

// ============================================================
// MODULE 17: REPORTS
// ============================================================

model ScheduledReport {
  id              String          @id @default(cuid())
  clientId        String          
  createdByUserId String
  reportCode      String
  reportName      String
  description     String?
  frequency       ReportFrequency
  format          ReportFormat    @default(XLSX)
  filters         Json?
  recipientEmails Json?
  isActive        Boolean         @default(true)
  nextRunAt       DateTime?
  lastRunAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  createdBy    User                @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  deliveryLogs ReportDeliveryLog[]

  @@index([clientId])
  @@index([createdByUserId])
  @@index([frequency])
  @@index([isActive])
  @@index([nextRunAt])
  @@index([deletedAt])
  @@map("scheduled_reports")
}

model ReportDeliveryLog {
  id              String      @id @default(cuid())
  reportId        String
  triggeredById   String?
  status          String
  format          ReportFormat
  fileUrl         String?
  fileKey         String?
  fileSizeBytes   Int?
  rowCount        Int?
  errorMessage    String?
  startedAt       DateTime    @default(now())
  completedAt     DateTime?
  emailSentAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  report      ScheduledReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  triggeredBy User?           @relation(fields: [triggeredById], references: [id], onDelete: SetNull)

  @@index([reportId])
  @@index([triggeredById])
  @@index([status])
  @@index([startedAt])
  @@map("report_delivery_log")
}

model SchemeEnrollment {
  id         String   @id @default(cuid())
  schemeId   String
  userId     String
  status     String   @default("ACTIVE")
  enrolledAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  scheme Scheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schemeId, userId])
  @@index([userId])
  @@index([schemeId])
  @@map("scheme_enrollments")
}

model SchemeTarget {
  id                 String   @id @default(cuid())
  schemeId           String
  userId             String
  targetValue        Float    @default(0)
  achievedValue      Float    @default(0)
  projectedIncentive Float?
  status             String   @default("ACTIVE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  scheme Scheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([schemeId])
  @@map("scheme_targets")
}

model LoginLog {
  id         String   @id @default(cuid())
  userId     String
  ipAddress  String?
  deviceInfo String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("login_logs")
}




// ============================================================
// MODULE 12 — Sales Data Upload
// ============================================================

model SalesUploadBatch {
  id             String   @id @default(cuid())
  clientId       String
  uploadedById   String
  month          String
  totalRows      Int      @default(0)
  acceptedCount  Int      @default(0)
  rejectedCount  Int      @default(0)
  status         String   @default("COMPLETED")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  uploadedBy    User                @relation("SalesUploadBatches", fields: [uploadedById], references: [id], onDelete: Restrict)
  salesRecords  OutletSalesRecord[]

  @@index([clientId])
  @@index([month])
  @@index([uploadedById])
  @@map("sales_upload_batches")
}

model OutletSalesRecord {
  id          String   @id @default(cuid())
  clientId    String
  outletCode  String
  outletName  String
  outletType  String
  month       String
  kpiValues   Json
  batchId     String

  batch     SalesUploadBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, outletCode, month])
  @@index([clientId])
  @@index([month])
  @@index([outletCode])
  @@index([batchId])
  @@map("outlet_sales_records")
}
