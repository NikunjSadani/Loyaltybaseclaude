generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  GIFSY_ADMIN
  CLIENT_ADMIN
  MIS_USER
  SALES_HO
  SALES_STATE_HEAD
  SALES_ASM
  SALES_SO
  SALES_ISR
  RETAILER
  WHOLESALER
  SUB_STOCKIST
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum OtpPurpose {
  LOGIN
  REGISTRATION
  PASSWORD_RESET
  KYC_CONSENT
  WITHDRAWAL
  PROFILE_UPDATE
  REDEMPTION_CONFIRM
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  EXPORT
  IMPORT
}

enum PartnerClassCode {
  CP_01
  CP_02
  CP_03
}

enum KycStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  PENDING_PENNY_DROP
  PENDING_AGREEMENT
  PENDING_SO_APPROVAL    // XSR submitted â†’ awaiting SO (or escalated approver)
  PENDING_ASM_APPROVAL   // SO submitted or escalated past SO â†’ awaiting ASM
  PENDING_RSM_APPROVAL   // Escalated past ASM â†’ awaiting RSM (SALES_STATE_HEAD)
  PENDING_GIFSY          // First approver done â†’ awaiting Gifsy final approval
  APPROVED
  REJECTED
  RE_UPLOAD_REQUIRED
  RESUBMISSION_REQUIRED  // Alias used by frontend â€” maps to RE_UPLOAD_REQUIRED
  RE_KYC_REQUIRED        // Full re-KYC needed (e.g. KYC expired)
  SUSPENDED
}

enum KycDocumentType {
  AADHAAR_FRONT
  AADHAAR_BACK
  PAN_CARD
  GST_CERTIFICATE
  TRADE_LICENSE
  SHOP_ESTABLISHMENT
  BANK_PASSBOOK
  CANCELLED_CHEQUE
  SELFIE
  SIGNATURE
  OUTLET_PHOTO        // photo of the outlet taken by XSR during the KYC visit
  OTHER
}

enum KycDocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DataRequestType {
  ACCESS
  CORRECTION
  DELETION
  PORTABILITY
}

enum DataRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum SchemeType {
  PURCHASE_INCENTIVE
  VISIBILITY
  GROWTH_INCENTIVE
  REFERRAL
  WELCOME_BONUS
  MILESTONE
  SLAB_BASED
  TARGET_BASED
}

enum SchemeStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  CANCELLED
}

enum RuleType {
  MIN_PURCHASE_VALUE
  MIN_PURCHASE_QTY
  SKU_INCLUSION
  SKU_EXCLUSION
  CATEGORY_INCLUSION
  CATEGORY_EXCLUSION
  PARTNER_CLASS
  TIER_CONDITION
  GEOGRAPHY_CONDITION
  SLAB_THRESHOLD
