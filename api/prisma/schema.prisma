  LOCK
  UNLOCK
  REDEEM
  EXPIRE
  ADJUST
  REVERSE
}

enum RedemptionStatus {
  PENDING
  CONFIRMED
  PROCESSING
  DISPATCHED
  DELIVERED
  CANCELLED
  RETURNED
  FAILED
}

enum RewardCatalogStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
  DISCONTINUED
}

enum PayoutMode {
  GIFT_CARD
  UPI
  BANK_TRANSFER
  PHYSICAL_GIFT
}

enum PayoutStatus {
  PENDING
  INITIATED
  PROCESSING
  SUCCESS
  FAILED
  REVERSED
  HOLD
}

enum PayoutBatchStatus {
  DRAFT
  SUBMITTED
  PROCESSING
  PARTIALLY_COMPLETED
  COMPLETED
  FAILED
  CANCELLED
}

enum FundLedgerType {
  RECEIPT
  DISBURSEMENT
  ADJUSTMENT
  REVERSAL
}

enum VisibilityStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  FLAGGED
}

enum VisibilityProgramStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING_USER
  RESOLVED
  CLOSED
  ESCALATED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketCategory {
  KYC
  POINTS
  REDEMPTION
  PAYOUT
  SCHEME
  TECHNICAL
  ACCOUNT
  OTHER
}

enum NotificationChannel {
  SMS
  EMAIL
  PUSH
  WHATSAPP
  IN_APP
}

enum NotificationStatus {
  QUEUED
  PROCESSING
  SENT
  DELIVERED
  FAILED
  CANCELLED
}

enum ReportFormat {
  CSV
  XLSX
  PDF
}

enum ReportFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ON_DEMAND
}

enum SalesUploadStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIALLY_COMPLETED
  FAILED
}

enum TargetPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum TargetStatus {
  ACTIVE
  ACHIEVED
  MISSED
  CANCELLED
}

enum LeaderboardType {
  POINTS_EARNED
  SALES_VALUE
  GROWTH_PERCENTAGE
  REDEMPTION_COUNT
}

enum LeaderboardPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  ALL_TIME
}

enum BannerPosition {
  HOME_TOP
  HOME_MIDDLE
  HOME_BOTTOM
  CATALOG_TOP
  SCHEME_PAGE
  DASHBOARD
}

enum BannerStatus {
  ACTIVE
  INACTIVE
  SCHEDULED
}

// ============================================================
// MODULE 1: USERS & AUTH
// ============================================================

model User {
  id                String     @id @default(cuid())
  clientId          String
  phone             String
  email             String?
  passwordHash      String?
  name              String
  role              UserRole
  status            UserStatus @default(PENDING)
  avatarUrl         String?
  preferredLanguage String     @default("en")
  fcmToken          String?
  lastLoginAt       DateTime?
  loginCount        Int        @default(0)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  // Relations
  sessions              UserSession[]
  otpCodes              OtpCode[]
  auditLogs             AuditLog[]            @relation("AuditActor")
  affectedAuditLogs     AuditLog[]            @relation("AuditTarget")
  salesUser             SalesUser?
  channelPartner        ChannelPartner?
  kycSubmissions        KycSubmission[]
  tickets               Ticket[]              @relation("TicketCreator")
  assignedTickets       Ticket[]              @relation("TicketAssignee")
  ticketMessages        TicketMessage[]
  notificationQueue     NotificationQueue[]
  dataRequests          DataRequest[]
  consentRecords        ConsentRecord[]
  scheduledReports      ScheduledReport[]
  reportDeliveryLogs    ReportDeliveryLog[]
  schemeEnrollments     SchemeEnrollment[]
  schemeTargets         SchemeTarget[]
  loginLogs             LoginLog[]
  salesUploadBatches    SalesUploadBatch[]    @relation("SalesUploadBatches")

  @@unique([clientId, phone])              // same phone can exist across different clients
  @@unique([clientId, email])              // email scoped per client (nullable handled by Postgres partial index)
  @@index([clientId])
  @@index([phone])
  @@index([email])
  @@index([role])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model UserSession {
  id           String    @id @default(cuid())
  userId       String
  token        String    @unique
  refreshToken String?   @unique
  deviceId     String?
  deviceName   String?
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("user_sessions")
}

model OtpCode {
  id          String      @id @default(cuid())
  userId      String?
  phone       String
  code        String
  purpose     OtpPurpose
  expiresAt   DateTime
  verifiedAt  DateTime?
  attempts    Int         @default(0)
  maxAttempts Int         @default(3)
  ipAddress   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone])
  @@index([userId])
  @@index([purpose])
  @@index([expiresAt])
  @@map("otp_codes")
}

model AuditLog {
  id           String      @id @default(cuid())
  actorId      String?
  targetUserId String?
  action       AuditAction
  entityType   String
  entityId     String
  oldValues    Json?
  newValues    Json?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime    @default(now())

  // ── Point-in-time snapshot (preserved even if actor is deactivated/blanked) ──
  actorName    String?   // actor's display name at time of action
  actorPhone   String?   // actor's phone at time of action
  actorEmpCode String?   // actor's employee code (sales users only)

  actor      User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetUser User? @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([targetUserId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// MODULE 2: HIERARCHY
// ============================================================

model SalesHierarchyLevel {
  id          String   @id @default(cuid())
  clientId    String
  code        String
  name        String
  level       Int      @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salesUsers SalesUser[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([level])
  @@map("sales_hierarchy_levels")
}

model SalesUser {
  id              String    @id @default(cuid())
  userId          String    @unique
  hierarchyLevelId String
  employeeCode    String    @unique
  reportingToId   String?
  region          String?
  zone            String?
  isActive        Boolean   @default(true)
  joinedAt        DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  hierarchyLevel SalesHierarchyLevel   @relation(fields: [hierarchyLevelId], references: [id])
  reportingTo    SalesUser?            @relation("SalesUserReporting", fields: [reportingToId], references: [id])
  subordinates   SalesUser[]           @relation("SalesUserReporting")
  assignments    SalesUserAssignment[]

  @@index([userId])
  @@index([hierarchyLevelId])
  @@index([reportingToId])
  @@index([employeeCode])
  @@index([deletedAt])
  @@map("sales_users")
}

model SalesUserAssignment {
  id              String    @id @default(cuid())
  salesUserId     String
  partnerId       String?
  outletId        String?
  assignedAt      DateTime  @default(now())
  unassignedAt    DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // ── Point-in-time snapshot of the assigned sales user ────────────────────
  // Preserved even if the employee is later deactivated, blanked, or restructured
  salesUserName    String?   // sales user's name at time of assignment
  salesUserPhone   String?   // sales user's phone at time of assignment
  salesUserEmpCode String?   // sales user's employee code at time of assignment

  // ── Snapshot of who created / closed this assignment ─────────────────────
  assignedByName   String?   // admin/manager who created this assignment
  assignedByPhone  String?
  assignedByEmpCode String?
  unassignedByName  String?   // admin/manager who closed this assignment
  unassignedByPhone String?
  unassignedByEmpCode String?

  salesUser SalesUser       @relation(fields: [salesUserId], references: [id], onDelete: Cascade)
  partner   ChannelPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  outlet    Outlet?         @relation(fields: [outletId], references: [id], onDelete: SetNull)

  @@index([salesUserId])
  @@index([partnerId])
  @@index([outletId])
  @@map("sales_user_assignments")
}

// ============================================================
// MODULE 3: CHANNEL PARTNERS
// ============================================================

model PartnerClassConfig {
  id          String          @id @default(cuid())
  clientId    String
  code        PartnerClassCode 
  name        String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  channelPartners ChannelPartner[]
  tierConfigs     TierConfig[]

  @@index([clientId])
  @@map("channel_partner_classes")
}

model TierConfig {
  id               String              @id @default(cuid())
  partnerClassId   String
  tierName         String
  tierLevel        Int
  minPoints        Int
  maxPoints        Int?
  pointsMultiplier Decimal             @db.Decimal(5, 2)
  holdingPeriodDays Int               @default(30)
  benefits         Json?
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  partnerClass       PartnerClassConfig    @relation(fields: [partnerClassId], references: [id])
  partnerTierHistory PartnerTierHistory[]
  currentTierPartners ChannelPartner[]    @relation("CurrentTier")

  @@unique([partnerClassId, tierLevel])
  @@index([partnerClassId])
  @@map("tier_configs")
}

model ChannelPartner {
  id               String              @id @default(cuid())
  clientId         String                                    // denormalised for efficient tenant filtering
  userId           String              @unique
  partnerClassId   String
  partnerCode      String
  businessName     String
  ownerName        String
  phone            String
  email            String?
  gstNumber        String?
  panNumber        String?
  currentTierConfigId String?
  totalEarnedPoints   Int             @default(0)
  referredBy       String?
  isActive         Boolean             @default(true)
  onboardedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?

  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  partnerClass     PartnerClassConfig    @relation(fields: [partnerClassId], references: [id])
  currentTier      TierConfig?           @relation("CurrentTier", fields: [currentTierConfigId], references: [id])
  tierHistory      PartnerTierHistory[]
  outlets          Outlet[]
  kycSubmissions   KycSubmission[]
  wallets          Wallet[]
  salesAssignments SalesUserAssignment[]
  targets          Target[]
  targetAchievements TargetAchievement[]
  visibilitySubmissions VisibilitySubmission[]
  redemptionOrders RedemptionOrder[]
  payoutTransactions PayoutTransaction[]
  leaderboardEntries LeaderboardEntry[]

  @@unique([clientId, partnerCode])
  @@unique([clientId, gstNumber])
  @@index([clientId])
  @@index([userId])
  @@index([partnerClassId])
  @@index([partnerCode])
  @@index([gstNumber])
  @@index([isActive])
  @@index([deletedAt])
  @@map("channel_partners")
}

model PartnerTierHistory {
  id             String     @id @default(cuid())
  partnerId      String
  tierConfigId   String
  changedAt      DateTime   @default(now())
  changedReason  String?
  previousTierId String?
  pointsAtChange Int
  createdAt      DateTime   @default(now())

  partner    ChannelPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  tierConfig TierConfig     @relation(fields: [tierConfigId], references: [id])

  @@index([partnerId])
  @@index([tierConfigId])
  @@index([changedAt])
  @@map("partner_tier_history")
}

// ============================================================
// MODULE 4: KYC
// ============================================================

model KycSubmission {
  id                String    @id @default(cuid())
  userId            String
  partnerId         String?
  status            KycStatus @default(DRAFT)
  submittedAt       DateTime?
  reviewedAt        DateTime?
  approvedAt        DateTime?
  rejectionReason   String?
  reviewerNotes     String?
  pennydropRef      String?
  pennydropStatus   String?
  pennydropVerifiedAt DateTime?
  agreementRef      String?
  agreementSignedAt DateTime?
  escalatedFrom     String?   // SalesRole that was skipped due to resignation (e.g. 'SO')
  version           Int       @default(1)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  partner        ChannelPartner?     @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  documents      KycDocument[]
  statusHistory  KycStatusHistory[]
  consentRecords ConsentRecord[]

  @@index([userId])
  @@index([partnerId])
  @@index([status])
  @@index([submittedAt])
  @@map("kyc_submissions")
}

model KycDocument {
  id              String            @id @default(cuid())
  kycSubmissionId String
  documentType    KycDocumentType
  fileUrl         String
  fileKey         String
  fileName        String?
  fileSizeBytes   Int?
  mimeType        String?
  status          KycDocumentStatus @default(PENDING)
  rejectionReason String?
  verifiedAt      DateTime?
  expiresAt       DateTime?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  kycSubmission KycSubmission @relation(fields: [kycSubmissionId], references: [id], onDelete: Cascade)

  @@index([kycSubmissionId])
  @@index([documentType])
  @@index([status])
  @@map("kyc_documents")
}

model KycStatusHistory {
  id              String    @id @default(cuid())
  kycSubmissionId String
  fromStatus      KycStatus?
  toStatus        KycStatus
  changedByUserId String?
  notes           String?
  metadata        Json?
  createdAt       DateTime  @default(now())

  // ── Point-in-time snapshot of the reviewer ────────────────────────────────
  // Tells you exactly who approved/rejected at that moment, even if their
  // profile is later blanked (resignation) or the position is abolished
  changedByName    String?   // reviewer's name at time of decision
  changedByPhone   String?   // reviewer's phone at time of decision
  changedByEmpCode String?   // reviewer's employee code (SO, ASM, RSM, etc.)

  kycSubmission KycSubmission @relation(fields: [kycSubmissionId], references: [id], onDelete: Cascade)

  @@index([kycSubmissionId])
  @@index([createdAt])
  @@map("kyc_status_history")
}

model ConsentRecord {
  id              String    @id @default(cuid())
  userId          String
  kycSubmissionId String?
  consentType     String
  consentText     String
  version         String
  ipAddress       String?
  deviceInfo      String?
  consentedAt     DateTime  @default(now())
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  kycSubmission KycSubmission? @relation(fields: [kycSubmissionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([kycSubmissionId])
  @@index([consentType])
  @@map("consent_records")
}

model DataRequest {
  id          String            @id @default(cuid())
  userId      String
  requestType DataRequestType
  status      DataRequestStatus @default(PENDING)
  notes       String?
  processedBy String?
  processedAt DateTime?
  responseUrl String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([requestType])
  @@map("data_requests")
}

// ============================================================
// MODULE 5: OUTLET
// ============================================================

model OutletType {
  id          String   @id @default(cuid())
  code        String   @unique                 // e.g. RETAILER, WHOLESALER, SUB_STOCKIST, SSS_TOT
  name        String                           // display name — can be updated without a migration
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  outlets       Outlet[]
  clientConfigs OutletTypeClientConfig[]

  @@map("outlet_types")
}

// Per-tenant configuration for each outlet type.
// GIFSY_ADMIN or CLIENT_ADMIN can toggle features per outlet type per client.
model OutletTypeClientConfig {
  id            String   @id @default(cuid())
  clientId      String
  outletTypeId  String

  // ── Visibility ────────────────────────────────────────────────────────────
  isEnabled     Boolean  @default(true)       // show/hide this outlet type for the client
  displayName   String?                        // client-specific label override

  // ── Feature flags ─────────────────────────────────────────────────────────
  loyaltyEnabled      Boolean @default(true)  // can earn / redeem points
  schemesEnabled      Boolean @default(true)  // eligible for scheme enrolment
  visibilityEnabled   Boolean @default(true)  // can submit visibility programs
  payoutsEnabled      Boolean @default(true)  // can receive payouts
  leaderboardEnabled  Boolean @default(true)  // appears in leaderboard rankings
  targetsEnabled      Boolean @default(true)  // targets can be assigned
  kycRequired         Boolean @default(true)  // KYC is mandatory before activation

  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outletType OutletType @relation(fields: [outletTypeId], references: [id], onDelete: Cascade)

  @@unique([clientId, outletTypeId])
  @@index([clientId])
  @@index([outletTypeId])
  @@map("outlet_type_client_configs")
}

model Outlet {
  id             String    @id @default(cuid())
  partnerId      String
  outletTypeId   String
  outletCode     String    @unique
  name           String
  ownerName      String?
  phone          String?
  addressLine1   String
  addressLine2   String?
  city           String
  district       String?
  state          String
  pincode        String
  country        String    @default("IN")
  latitude       Decimal?  @db.Decimal(10, 8)
  longitude      Decimal?  @db.Decimal(11, 8)
  isActive       Boolean   @default(true)
  isPrimary      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  partner          ChannelPartner        @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  outletType       OutletType            @relation(fields: [outletTypeId], references: [id])
  geoHistory       OutletGeoHistory[]
  salesAssignments SalesUserAssignment[]
  visibilitySubmissions VisibilitySubmission[]

  @@index([partnerId])
  @@index([outletTypeId])
  @@index([pincode])
  @@index([state])
  @@index([isActive])
  @@index([deletedAt])
  @@map("outlets")
}

model OutletGeoHistory {
  id          String   @id @default(cuid())
  outletId    String
  latitude    Decimal  @db.Decimal(10, 8)
  longitude   Decimal  @db.Decimal(11, 8)
  capturedAt  DateTime @default(now())
  deviceInfo  String?
  accuracy    Decimal? @db.Decimal(8, 2)
  createdAt   DateTime @default(now())

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
  @@index([capturedAt])
  @@map("outlet_geo_history")
}

// ============================================================
// MODULE 6: SKU / PRODUCT
// ============================================================

model Category {
  id          String    @id @default(cuid())
  clientId    String    
  parentId    String?
  code        String    
  name        String
  description String?
  imageUrl    String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  skuMappings SkuCategoryMapping[]

  @@index([clientId])
  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

model Sku {
  id              String    @id @default(cuid())
  clientId        String
  skuCode         String    
  name            String
  description     String?
  brand           String?
  uom             String
  packSize        Decimal?  @db.Decimal(10, 3)
  mrpPaise        Int
  dealerPricePaise Int?
  imageUrl        String?
