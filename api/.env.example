# ─────────────────────────────────────────────────────────────────────────────
# api/.env.example
# Copy to .env and fill in real values for local development.
# In production, all values come from GCP Secret Manager (never from .env).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# For local dev, run Cloud SQL Auth Proxy then use 127.0.0.1:
#   cloud-sql-proxy gifsy-platform:asia-south1:gifsy-db
# Cloud Run uses Unix socket automatically (set by Secret Manager).
DATABASE_URL="postgresql://gifsy_user:your_password@127.0.0.1:5432/gifsy_dev"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="dev-only-insecure-secret-change-in-prod"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed frontend origins
CORS_ORIGINS="http://localhost:3000"

# ── MSG91 (notifications) ─────────────────────────────────────────────────────
# Leave blank to skip real SMS in dev (OTP logged to console instead).
# Get these from MSG91 dashboard → API → Auth Key and Templates.
MSG91_AUTH_KEY=""
MSG91_SENDER_ID="GIFSY"
# OTP template: used for login OTPs (MSG91 dashboard → OTP → Templates)
MSG91_OTP_TEMPLATE_ID=""
# SMS template: used for general notifications e.g. payout alerts (Flow template)
MSG91_SMS_TEMPLATE_ID=""

# ── Dev overrides ─────────────────────────────────────────────────────────────
# FIXED_OTP=123456 — set this in .env to bypass real OTP in dev/staging.
# NEVER set this in production Secret Manager.
FIXED_OTP=123456

# ── GCS (file uploads) ────────────────────────────────────────────────────────
GCS_BUCKET="gifsy-platform-files"
GCP_PROJECT_ID="gifsy-platform"
# For local dev, set GOOGLE_APPLICATION_CREDENTIALS to a service account key
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/dev-sa-key.json"
